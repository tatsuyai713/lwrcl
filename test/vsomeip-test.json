{
    "unicast": "127.0.0.1",
    "logging": {
        "level": "info",
        "console": "true",
        "file": { "enable": "false" },
        "dlt": "false"
    },
    "applications": [
        { "name": "routingmanagerd", "id": "0x0001" }
    ],
    "services": [],
    "routing": {
        "host": {
            "name": "routingmanagerd",
            "unicast": "127.0.0.1",
            "port": "31490"
        },
        "guests": {
            "unicast": "127.0.0.1",
            "ports": {
                "lwrcl": {
                    "range": {
                        "first": "31492",
                        "last": "31999"
                    }
                }
            }
        }
    },
    "service-discovery": {
        "enable": "true",
        "multicast": "224.244.224.245",
        "port": "30490",
        "protocol": "udp",
        "initial_delay_min": "10",
        "initial_delay_max": "100",
        "repetitions_base_delay": "200",
        "repetitions_max": "3",
        "ttl": "3",
        "cyclic_offer_delay": "2000",
        "request_response_delay": "1500"
    }
}
